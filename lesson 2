# Создаём пустой список для участников
participants = []

# Заполняем данные для трёх участников
for i in range(1, 4):
    print(f"\n--- Участник {i} ---")
    name = input("Введите наименование участника: ")
    status = input("Введите статус (Истец, Ответчик, Третье лицо и т.д.): ")
    inn = input("Введите ИНН: ")
    
    # Создаём словарь с данными участника
    participant = {
        "name": name,
        "status": status,
        "inn": inn
    }
    
    # Добавляем словарь в список
    participants.append(participant)

# Выводим полученную структуру
print("\nСтруктура «Участники спора»:")
print(participants)
