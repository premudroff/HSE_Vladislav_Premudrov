# Задание 1. Создать ряд функций для проведения математических вычислений:
# функция вычисления факториала числа
def factorial(n):
    if n < 0:
        raise ValueError("необходимо положительное число")
    if n == 0:
        return 1
    result = 1
    for i in range(1, n + 1):
        result *= i
    return result

# функция вычисления наибольшего числа из трех
   def max_of_three(numbers):
    if len(numbers) != 3:
        raise ValueError("Должно быть ровно три числа")
    a, b, c = numbers
    # Сравниваем попарно
    greatest = a
    if b > greatest:
        greatest = b
    if c > greatest:
        greatest = c
    return greatest

# функция вычисления площади прямоугольного треугольника
def right_triangle_area(a, b):
    """
    Принимает длины катетов a и b, возвращает площадь прямоугольного треугольника.
    Формула: (a * b) / 2
    """
    if a <= 0 or b <= 0:
        raise ValueError("Длины катетов должны быть положительными числами")
    return (a * b) / 2


