# Задание 2. Предложить пользователю ввести время в секундах и перевести это время в нормальный формат: часы, минуты, секунды
user_input = input("Введите время в секундах (целое число): ")
# Проверяем, что введённая строка состоит только из цифр (и не пустая)
if user_input.isdigit():
    total_seconds = int(user_input)  # приведение к целому числу
        # Вычисляем часы, минуты и секунды
    hours = total_seconds // 3600
    minutes = (total_seconds % 3600) // 60
    seconds = total_seconds % 60
        # Выводим результат в формате ЧЧ:ММ:СС (с ведущими нулями)
    print(f"{hours:02}:{minutes:02}:{seconds:02}")
else:
    print("Ошибка: необходимо ввести целое положительное число, используя только цифры.")

# Задание 3 - запросить у пользователя число N и найти сумму чисел N+NN+NNN
n = int(input("Введите число от 1 до 9: "))
if 1 <= n <= 9:
    result = n + 11*n + 111*n
    print(f"{n} + {n*11} + {n*111} = {result}")
else:
    print("Ошибка: число должно быть от 1 до 9.")
